<?xml version='1.0' encoding='utf-8'?>
<fdml version="1.2">
  <meta>
    <title>Example 06 — Line Progress (v1.2)</title>
    <dance name="Example Line Progress" />
    <origin country="UNKNOWN" />
    <type genre="line" />
    <meter value="4/4" />
    <tempo bpm="112" />
    <formation text="line" />

    <geometry>
      <formation kind="line" />
      <roles>
        <role id="all" />
        <role id="both" />
        <role id="d1" />
        <role id="d2" />
        <role id="d3" />
        <role id="d4" />
      </roles>
    </geometry>
  </meta>

  <body>
    <geometry>
      <line id="line1">
        <order phase="initial">
          <slot who="d1" />
          <slot who="d2" />
          <slot who="d3" />
          <slot who="d4" />
        </order>
        <order phase="after">
          <slot who="d3" />
          <slot who="d4" />
          <slot who="d1" />
          <slot who="d2" />
        </order>
      </line>
    </geometry>

    <figure id="f-line-progress" name="Progress twice">
      <step who="both" action="forward" beats="2" startFoot="L">
        <geo>
          <primitive kind="move" who="both" />
          <primitive kind="progress" who="all" delta="1" />
        </geo>
      </step>
      <step who="both" action="back" beats="2" startFoot="R">
        <geo>
          <primitive kind="move" who="both" />
        </geo>
      </step>
      <step who="both" action="forward" beats="2" startFoot="L">
        <geo>
          <primitive kind="move" who="both" />
          <primitive kind="progress" who="all" delta="1" />
        </geo>
      </step>
      <step who="both" action="back" beats="2" startFoot="R">
        <geo>
          <primitive kind="move" who="both" />
        </geo>
      </step>
    </figure>
  </body>
</fdml>
