# FDML enrichment APIs (optional; keep core pipeline offline/deterministic)

# LLM + speech-to-text (free tier available)
GROQ_API_KEY=

# Optional alternate LLM routing with free models
OPENROUTER_API_KEY=

# OCR for scanned dance notes (free tier available)
OCR_SPACE_API_KEY=

# Translation API (free developer plan available)
DEEPL_API_KEY=

# Optional video metadata ingestion (free daily quota)
YOUTUBE_API_KEY=

# Safety switch for deterministic CI/local runs
FDML_OFFLINE=1

# Optional HTTP tuning for enrichment calls
FDML_HTTP_USER_AGENT=fdml-core-ingest/1.0
FDML_ENRICH_TIMEOUT_S=15
